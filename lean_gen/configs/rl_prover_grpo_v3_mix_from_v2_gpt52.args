--model-name-or-path /home/yueke/formalgen/lean_gen/rl_prover_critic_v2
--base-model-name-or-path deepseek-ai/DeepSeek-Prover-V2-7B
--output-dir /home/yueke/formalgen/lean_gen/rl_prover_critic_v3

# Mix: upweight hard fails while retaining general coverage (stability).
# Uses new `@N` repeat syntax (see rl_training_prover_process.py).
--tasks-jsonl /home/yueke/formalgen/lean_gen/itssm_rl_dataset_artifacts/itssm_lcb_v6_hard_fail_1770671000.jsonl@4,/home/yueke/formalgen/lean_gen/itssm_rl_dataset_artifacts/itssm_lcb_v6_hard_draftfail_1770671000.jsonl@2,/home/yueke/formalgen/lean_gen/itssm_lcb_v*_regen.jsonl

--peft qlora
--gradient-checkpointing

--num-generations 3
--generation-batch-size 2
--max-prompt-tokens 1536
--max-new-tokens 512
--min-present-target-tags 3

--dense-weight 0.2
--terminal-weight 0.8

--per-device-train-batch-size 1
--grad-accum 4
--max-steps 120
--logging-steps 10

--terminal-mode coder
--terminal-relative
--terminal-baseline draft
--terminal-abs-weight 0.0
--terminal-runtime-penalty 0.02
--dense-no-terminal-scale 0.0

--skip-baseline-perfect
--baseline-perfect-threshold 0.999999

--terminal-score shaped

--quality-reward llm
--quality-llm-provider amplify
--quality-llm-base-url https://prod-api.vanderbilt.ai
--quality-llm-model gpt-5.2
--quality-llm-strict

# Make terminal reward less noisy by matching evaluation-like revision decoding.
--qwen-base-url http://localhost:1234/v1
--qwen-model Qwen/Qwen3-Coder-30B-A3B-Instruct-FP8
--coder-max-tokens 12000
--coder-temperature 0.2
--coder-top-p 0.95
--coder-top-k 20
--coder-repetition-penalty 1.05
--coder-seed 0

--enable-checkpoints
--checkpoint-every-steps 10
--checkpoint-keep-last 5
--save-best-checkpoint
--best-checkpoint-metric reward
--best-checkpoint-min-steps 30

--abort-on-degenerate-terminal
--degenerate-terminal-max-calls 8
